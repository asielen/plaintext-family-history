# Root-level local asset libraries for a user's working archive (anchored to root only)
/photos/
/documents/
/inbox/
/private/
private/

# Rebuildable cache — regenerated from the files, never committed
.cache/
*.sqlite
*.sqlite-journal

# fha packet output — disposable export copies, never the archive's truth.
# Anchored to root only — a record tree's own 'out' subdirectory (sources/out/,
# …) is real archive content and must stay trackable.
/out/

# But DO keep fixture assets if/when added
!example-archive/documents/
!example-archive/photos/
!tests/fixtures/**

# Python / tooling noise (for when the fha suite is built)
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
dist/
build/
*.egg-info/

# Local Claude Code state — machine-specific permissions, never shared.
# (Tracked .claude/ content such as .claude/skills/ stays committed.)
.claude/settings.local.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
