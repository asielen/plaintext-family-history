# Root-level local asset libraries for a user's working archive (anchored to root only)
/photos/
/documents/
/inbox/
/private/
private/

# Rebuildable cache (databases) and generated deliverables (the built site, etc.)
# - both regenerated from the records, never committed
.cache/
generated/
# ...except the EXAMPLE archive ships its standalone site as a browsable showcase
# (the deterministic, redacted build). Never the unredacted linked preview.
!example-archive/generated/
example-archive/generated/site-linked/
*.sqlite
*.sqlite-journal

# fha packet output - disposable export copies, never the archive's truth.
# Anchored to root only - a record tree's own 'out' subdirectory (sources/out/,
# …) is real archive content and must stay trackable.
/out/

# fha install / update-tools footprints - these belong inside a *real archive*,
# never in the public spec repo. Ignored so a stray local test of `fha install`
# against a checked-out folder can't accidentally commit them. (manifest.json,
# the committed packing list, is NOT ignored - it is tracked on purpose.)
.plaintext-version
.plaintext-backup/

# But DO keep fixture assets if/when added
!example-archive/documents/
!example-archive/photos/
!tests/fixtures/**

# Python / tooling noise (for when the fha suite is built)
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
dist/
build/
*.egg-info/

# Local Claude Code state - permission grants are PERSONAL, never shared.
# A committed settings.json would pre-approve commands for everyone who clones
# this public repo; each user must approve their own permissions instead.
# (Tracked .claude/ content such as .claude/skills/ stays committed.)
.claude/settings.local.json
.claude/settings.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Claude Code agent worktrees (harness-managed, never commit)
.claude/worktrees/
