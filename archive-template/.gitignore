# Generated caches and site output — rebuilt by fha index / fha site / fha photoindex.
.cache/

# Binary asset roots. Photos and documents can be large; consider keeping them
# on an external drive and pointing roots: in fha.yaml at that location instead.
# Comment out the lines below if you want git to track originals in this repo.
photos/
documents/

# Staging area — inbox/ items are processed one at a time, not version-controlled.
inbox/

# Machine-local working-copy marker (git-ignored by design — see SPEC.md §12).
WORKING_COPY

# Backup directory created by fha update-tools.
.plaintext-backup/

# Python bytecode written by the fha tools at runtime.
__pycache__/
*.pyc
